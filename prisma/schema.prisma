generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  THERAPIST
  PATIENT
  ATHLETE
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum ProgramStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum ExerciseCategory {
  STRENGTH
  MOBILITY
  PLYOMETRICS
  CARDIO
  STABILITY
}

enum BodyRegion {
  KNEE
  SHOULDER
  BACK
  ANKLE
  HIP
  FULL_BODY
  CERVICAL
  THORACIC
  LUMBAR
  ELBOW
  WRIST
  FOOT
}

enum Difficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum MediaType {
  UPLOAD
  YOUTUBE
  VIMEO
}

enum LoadType {
  BODYWEIGHT
  WEIGHTED
  MACHINE
  BAND
}

enum MovementPattern {
  SQUAT
  LUNGE
  HINGE
  PUSH_HORIZONTAL
  PUSH_VERTICAL
  PULL_HORIZONTAL
  PULL_VERTICAL
  HIP_THRUST
  CALF_RAISE
  CORE
  ROTATION
  ISOLATION_UPPER
  ISOLATION_LOWER
  CARRY
  FULL_BODY
}

enum SessionStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

enum ProgramType {
  STRENGTH
  CARDIO
  MIXED
}

enum CardioActivity {
  RUNNING
  CYCLING
  ROWING
  SWIMMING
  CROSSTRAINER
  WALKING
  SKIERG
  ASSAULT_BIKE
  WATTBIKE
  STAIRCLIMBER
  OTHER
}

enum CardioProtocol {
  STEADY_STATE
  INTERVALS
  TEMPO
  FARTLEK
  ZONE_TRAINING
  THRESHOLD
  LONG_SLOW_DISTANCE
  WALK_RUN
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  role          UserRole  @default(PATIENT)
  avatarUrl     String?
  phone         String?
  dateOfBirth   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Therapist fields
  specialty     String?
  bio           String?
  licenseNumber String?

  // DPA (Verwerkingsovereenkomst — AVG verplicht)
  dpaAcceptedVersion String?
  dpaAcceptedAt      DateTime?

  // MFA
  mfaEnabled    Boolean   @default(false)
  mfaSecret     String?

  // Relations
  therapistPatients      PatientTherapist[]     @relation("TherapistRelation")
  patientTherapists      PatientTherapist[]     @relation("PatientRelation")
  createdPrograms        Program[]              @relation("ProgramCreator")
  patientPrograms        Program[]              @relation("ProgramPatient")
  exercises              Exercise[]
  collections            ExerciseCollection[]
  appointments           Appointment[]          @relation("PatientAppointments")
  therapistAppointments  Appointment[]          @relation("TherapistAppointments")
  sessionLogs            SessionLog[]
  cardioLogs             CardioLog[]
  notifications          Notification[]
  messages               Message[]
  createdWeekSchedules   WeekSchedule[]         @relation("CreatedWeekSchedules")
  patientWeekSchedules   WeekSchedule[]         @relation("PatientWeekSchedules")
  researchConsent        ResearchConsent?
  favoriteExercises      FavoriteExercise[]

  @@map("users")
}

model PatientTherapist {
  id          String   @id @default(cuid())
  therapist   User     @relation("TherapistRelation", fields: [therapistId], references: [id])
  therapistId String
  patient     User     @relation("PatientRelation", fields: [patientId], references: [id])
  patientId   String
  createdAt   DateTime @default(now())
  isActive    Boolean  @default(true)
  notes       String?

  @@unique([therapistId, patientId])
  @@map("patient_therapists")
}

model Exercise {
  id             String           @id @default(cuid())
  name           String
  description    String?
  category       ExerciseCategory
  bodyRegion     BodyRegion[]
  difficulty     Difficulty       @default(BEGINNER)
  mediaType      MediaType?
  videoUrl       String?
  thumbnailUrl   String?
  instructions   String[]
  tips           String[]
  tags           String[]
  isPublic       Boolean          @default(false)
  loadType       LoadType         @default(BODYWEIGHT)
  isUnilateral   Boolean          @default(false)
  movementPattern MovementPattern?
  trackOneRepMax Boolean          @default(false)
  createdBy      User             @relation(fields: [createdById], references: [id])
  createdById    String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  // Muscle loading (1-5 per muscle group)
  muscleLoads    MuscleLoad[]

  // Progression variants (self-referential)
  easierVariantId String?
  easierVariant   Exercise?  @relation("ProgressionEasier", fields: [easierVariantId], references: [id])
  easierOf        Exercise[] @relation("ProgressionEasier")
  harderVariantId String?
  harderVariant   Exercise?  @relation("ProgressionHarder", fields: [harderVariantId], references: [id])
  harderOf        Exercise[] @relation("ProgressionHarder")

  programExercises ProgramExercise[]
  collectionItems  ExerciseCollectionItem[]
  favoritedBy      FavoriteExercise[]

  @@map("exercises")
}

model FavoriteExercise {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  exercise   Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  exerciseId String
  createdAt  DateTime @default(now())

  @@unique([userId, exerciseId])
  @@index([userId])
  @@map("favorite_exercises")
}

model MuscleLoad {
  id         String   @id @default(cuid())
  exercise   Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  exerciseId String
  muscle     String   // e.g. "Quadriceps", "Hamstrings"
  load       Int      // 1-5

  @@unique([exerciseId, muscle])
  @@map("muscle_loads")
}

model ExerciseCollection {
  id          String   @id @default(cuid())
  name        String
  color       String?  // hex color label
  therapist   User     @relation(fields: [therapistId], references: [id])
  therapistId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items ExerciseCollectionItem[]

  @@map("exercise_collections")
}

model ExerciseCollectionItem {
  id           String             @id @default(cuid())
  collection   ExerciseCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  collectionId String
  exercise     Exercise           @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  exerciseId   String
  addedAt      DateTime           @default(now())

  @@unique([collectionId, exerciseId])
  @@map("exercise_collection_items")
}

model Program {
  id           String        @id @default(cuid())
  name         String
  description  String?
  status       ProgramStatus @default(DRAFT)
  type         ProgramType   @default(STRENGTH)
  isTemplate   Boolean       @default(false)
  weeks        Int           @default(4)
  daysPerWeek  Int           @default(3)
  startDate    DateTime?
  endDate      DateTime?
  cardioParams Json?         // CardioParams JSONB for cardio programs

  tendinopathyMode Boolean       @default(false)
  trackOneRepMax   Boolean       @default(false)

  creator   User    @relation("ProgramCreator", fields: [creatorId], references: [id])
  creatorId String
  patient   User?   @relation("ProgramPatient", fields: [patientId], references: [id])
  patientId String?

  exercises        ProgramExercise[]
  sessionLogs      SessionLog[]
  weekScheduleDays WeekScheduleDay[]
  cardioLogs       CardioLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("programs")
}

model CardioLog {
  id           String          @id @default(cuid())
  program      Program?        @relation(fields: [programId], references: [id])
  programId    String?
  patient      User            @relation(fields: [patientId], references: [id])
  patientId    String
  activity     CardioActivity
  protocol     CardioProtocol
  durationSec  Int             // seconds
  distanceM    Int?            // meters
  avgHeartRate Int?
  maxHeartRate Int?
  zone         Int?            // 1-5
  calories     Int?
  rpe          Int?            // 1-10
  painLevel    Int?            // 0-10
  notes        String?
  intervals    Json?           // interval details JSONB
  completedAt  DateTime        @default(now())
  createdAt    DateTime        @default(now())

  @@map("cardio_logs")
}

model WeekSchedule {
  id          String            @id
  name        String
  description String?
  creatorId   String
  creator     User              @relation("CreatedWeekSchedules", fields: [creatorId], references: [id])
  patientId   String?
  patient     User?             @relation("PatientWeekSchedules", fields: [patientId], references: [id])
  startDate   DateTime?
  endDate     DateTime?
  isTemplate  Boolean           @default(false)
  days        WeekScheduleDay[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@map("week_schedules")
}

model WeekScheduleDay {
  id             String       @id
  weekScheduleId String
  weekSchedule   WeekSchedule @relation(fields: [weekScheduleId], references: [id], onDelete: Cascade)
  dayOfWeek      Int
  programId      String?
  program        Program?     @relation(fields: [programId], references: [id])

  @@map("week_schedule_days")
}

model ProgramExercise {
  id             String   @id @default(cuid())
  program        Program  @relation(fields: [programId], references: [id], onDelete: Cascade)
  programId      String
  exercise       Exercise @relation(fields: [exerciseId], references: [id])
  exerciseId     String
  week           Int      @default(1)
  day            Int      @default(1)
  order          Int      @default(0)
  sets           Int      @default(3)
  reps           Int      @default(10)
  repUnit        String   @default("reps")
  restTime       Int      @default(60)
  supersetGroup  String?
  supersetOrder  Int      @default(0)
  notes          String?

  @@map("program_exercises")
}

model SessionLog {
  id            String        @id @default(cuid())
  program       Program?      @relation(fields: [programId], references: [id])
  programId     String?
  patient       User          @relation(fields: [patientId], references: [id])
  patientId     String
  status        SessionStatus @default(PENDING)
  scheduledAt   DateTime
  completedAt   DateTime?
  duration      Int?          // seconds
  notes         String?
  painLevel     Int?          // 0-10
  exertionLevel Int?          // 0-10 RPE

  exerciseLogs ExerciseLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("session_logs")
}

model ExerciseLog {
  id                  String     @id @default(cuid())
  session             SessionLog @relation(fields: [sessionId], references: [id])
  sessionId           String
  exerciseId          String
  setsCompleted       Int?
  repsCompleted       Int?
  duration            Int?
  notes               String?
  painLevel           Int?
  weight              Float?     // kg used in last set
  estimatedOneRepMax  Float?     // Epley: weight × (1 + reps/30)
  painDuring          Int?       // 0-10 NRS, tendinopathy mode
  painAfter24h        Int?       // 0-10 NRS, filled via follow-up
  morningStiffness    Int?       // 0-10, filled via follow-up

  @@map("exercise_logs")
}

model Appointment {
  id          String            @id @default(cuid())
  patient     User              @relation("PatientAppointments", fields: [patientId], references: [id])
  patientId   String
  therapist   User              @relation("TherapistAppointments", fields: [therapistId], references: [id])
  therapistId String
  status      AppointmentStatus @default(SCHEDULED)
  scheduledAt DateTime
  duration    Int               // minutes
  notes       String?
  location    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("appointments")
}

model Notification {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  title     String
  body      String
  read      Boolean  @default(false)
  type      String
  data      Json?
  createdAt DateTime @default(now())

  @@map("notifications")
}

model Message {
  id          String   @id @default(cuid())
  sender      User     @relation(fields: [senderId], references: [id])
  senderId    String
  recipientId String
  content     String
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@map("messages")
}

// ─── Research / GDPR ──────────────────────────────────────────────────────────

model ResearchConsent {
  id             String    @id @default(cuid())
  userId         String    @unique
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  consentGiven   Boolean   @default(false)
  consentVersion String    @default("1.0")
  consentGivenAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@map("research_consents")
}

// SECURITY: AnonymousIdMapping is NEVER exposed via API or tRPC.
// Only server-side functions may read/write this table.
model AnonymousIdMapping {
  id          String   @id @default(cuid())
  userId      String   @unique
  anonymousId String   @unique @default(cuid())
  createdAt   DateTime @default(now())

  @@map("anonymous_id_mappings")
}

model AnonymizedRecord {
  id                String   @id @default(cuid())
  // anonymousId references AnonymousIdMapping.anonymousId — no direct FK to prevent reverse lookup
  anonymousId       String
  recordDate        DateTime
  ageAtRecord       Int      // computed from dateOfBirth at time of recording; DOB not stored
  diagnosisCategory String?  // normalized diagnosis category (e.g. "ACL", "Schouder impingement")
  exerciseName      String?
  setsCompleted     Int?
  repsCompleted     Int?
  sessionDuration   Int?     // seconds
  painLevel         Int?     // 0-10
  exertionLevel     Int?     // 0-10 RPE
  promData          Json?    // PROM scores placeholder
  createdAt         DateTime @default(now())

  @@map("anonymized_records")
}

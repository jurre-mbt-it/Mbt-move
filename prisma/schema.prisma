generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  THERAPIST
  PATIENT
  ATHLETE
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum ProgramStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum ExerciseCategory {
  STRENGTH
  MOBILITY
  PLYOMETRICS
  CARDIO
  STABILITY
}

enum BodyRegion {
  KNEE
  SHOULDER
  BACK
  ANKLE
  HIP
  FULL_BODY
  CERVICAL
  THORACIC
  LUMBAR
  ELBOW
  WRIST
  FOOT
}

enum Difficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum MediaType {
  UPLOAD
  YOUTUBE
  VIMEO
}

enum LoadType {
  BODYWEIGHT
  WEIGHTED
  MACHINE
  BAND
}

enum MovementPattern {
  SQUAT
  LUNGE
  HINGE
  PUSH_HORIZONTAL
  PUSH_VERTICAL
  PULL_HORIZONTAL
  PULL_VERTICAL
  HIP_THRUST
  CALF_RAISE
  CORE
  ROTATION
  ISOLATION_UPPER
  ISOLATION_LOWER
  CARRY
  FULL_BODY
}

enum SessionStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

enum ProgramType {
  STRENGTH
  CARDIO
  MIXED
}

enum CardioActivity {
  RUNNING
  CYCLING
  ROWING
  SWIMMING
  CROSSTRAINER
  WALKING
  SKIERG
  ASSAULT_BIKE
  WATTBIKE
  STAIRCLIMBER
  OTHER
}

enum CardioProtocol {
  STEADY_STATE
  INTERVALS
  TEMPO
  FARTLEK
  ZONE_TRAINING
  THRESHOLD
  LONG_SLOW_DISTANCE
  WALK_RUN
}

// ─── Clinical Insight Engine (CIE) ───────────────────────────────────────────

enum InsightUrgency {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum InsightStatus {
  OPEN
  FOLLOWED_UP
  DISMISSED
  SNOOZED
  EXPIRED
}

enum InsightActionType {
  VIEWED
  FOLLOWED_UP
  DISMISSED
  SNOOZED
  REOPENED
}

// ─── Revalidatie-protocollen (stoplicht-tracker) ─────────────────────────────

enum RehabCriterionStatusValue {
  NOT_MET       // rood
  IN_PROGRESS   // oranje — bijna
  MET           // groen — behaald
}

enum RehabCriterionInputType {
  NUMERIC   // bv 125 (graden), 95 (%), 20 (reps)
  TEXT      // kwalitatief ("goed" / "matig" / "slecht")
  PASS_FAIL // slagen / niet slagen
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  role          UserRole  @default(PATIENT)
  avatarUrl     String?
  phone         String?
  dateOfBirth   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Therapist fields
  specialty     String?
  bio           String?
  licenseNumber String?

  // Patient fields — blessure / injury info
  injuryInfo                String?
  injuryVisibleToTherapist  Boolean  @default(false)

  // DPA (Verwerkingsovereenkomst — AVG verplicht)
  dpaAcceptedVersion String?
  dpaAcceptedAt      DateTime?

  // MFA
  mfaEnabled        Boolean   @default(false)
  mfaSecret         String?
  mfaEnforcedAt     DateTime? // moment waarop admin/therapist rol MFA verplicht kreeg
  mfaLastBackupCodesGeneratedAt DateTime?

  // AVG art. 17 — right to be forgotten
  deletedAt             DateTime?  // soft-delete tombstone (records stay during 30-day grace)
  deletionRequestedAt   DateTime?  // when patient requested deletion

  // Multi-tenant: praktijk-scope. null = legacy / admin / cross-tenant.
  practiceId    String?
  practice      Practice? @relation(fields: [practiceId], references: [id], onDelete: SetNull)

  // Relations
  therapistPatients      PatientTherapist[]     @relation("TherapistRelation")
  patientTherapists      PatientTherapist[]     @relation("PatientRelation")
  createdPrograms        Program[]              @relation("ProgramCreator")
  patientPrograms        Program[]              @relation("ProgramPatient")
  exercises              Exercise[]
  collections            ExerciseCollection[]
  appointments           Appointment[]          @relation("PatientAppointments")
  therapistAppointments  Appointment[]          @relation("TherapistAppointments")
  sessionLogs            SessionLog[]
  cardioLogs             CardioLog[]
  notifications          Notification[]
  messages               Message[]
  createdWeekSchedules   WeekSchedule[]         @relation("CreatedWeekSchedules")
  patientWeekSchedules   WeekSchedule[]         @relation("PatientWeekSchedules")
  researchConsent        ResearchConsent?
  favoriteExercises      FavoriteExercise[]
  wellnessChecks         WellnessCheck[]
  invitesSent            InviteCode[]           @relation("InviteSender")
  auditLogs              AuditLog[]
  mfaBackupCodes         MfaBackupCode[]

  // CIE relations
  patientInsightStatus   PatientInsightStatus?  @relation("PatientInsightStatusPatient")
  insightStatusEnabled   PatientInsightStatus[] @relation("PatientInsightStatusEnabler")
  insights               Insight[]              @relation("InsightPatient")
  insightStatusChanges   Insight[]              @relation("InsightStatusChanger")
  insightActions         InsightAction[]        @relation("InsightActionActor")
  insightPrefs           TherapistInsightPref?

  // Rehab-tracker relations
  rehabTracker           PatientRehabTracker?   @relation("RehabTrackerPatient")
  rehabTrackersActivated PatientRehabTracker[]  @relation("RehabTrackerActivator")
  rehabStatusUpdates     RehabCriterionStatus[] @relation("RehabStatusUpdater")

  @@index([deletedAt])
  @@map("users")
}

/// Eén-voor-één-bruikbare MFA recovery-codes. We slaan ALLEEN de hash op,
/// patient/therapist moet ze zelf bewaren (print / password-manager).
/// Bij `usedAt != null` is de code al verbrand en kan niet opnieuw.
model MfaBackupCode {
  id          String    @id @default(cuid())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  codeHash    String    @unique
  usedAt      DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([userId, usedAt])
  @@map("mfa_backup_codes")
}

model WellnessCheck {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  date      DateTime // start-of-day, 1 per user per day
  sleep     Int      // 1-5 (5 = great sleep)
  soreness  Int      // 1-5 (5 = no soreness)
  fatigue   Int      // 1-5 (5 = fresh)
  mood      Int      // 1-5 (5 = great)
  stress    Int      // 1-5 (5 = calm)
  notes     String?
  createdAt DateTime @default(now())

  @@unique([userId, date])
  @@index([userId, date])
  @@map("wellness_checks")
}

enum PatientAccessStatus {
  PENDING
  APPROVED
  DECLINED
  REVOKED
}

model PatientTherapist {
  id           String              @id @default(cuid())
  therapist    User                @relation("TherapistRelation", fields: [therapistId], references: [id])
  therapistId  String
  patient      User                @relation("PatientRelation", fields: [patientId], references: [id])
  patientId    String
  createdAt    DateTime            @default(now())
  isActive     Boolean             @default(true)
  // Consent-workflow: patient moet expliciet toestemming geven. Bestaande
  // rijen krijgen default APPROVED om huidige koppelingen niet te breken.
  status       PatientAccessStatus @default(APPROVED)
  requestedAt  DateTime?
  respondedAt  DateTime?
  notes        String?

  @@unique([therapistId, patientId])
  @@map("patient_therapists")
}

model Exercise {
  id             String           @id @default(cuid())
  name           String
  description    String?
  category       ExerciseCategory
  bodyRegion     BodyRegion[]
  difficulty     Difficulty       @default(BEGINNER)
  mediaType      MediaType?
  videoUrl       String?
  thumbnailUrl   String?
  instructions   String[]
  tips           String[]
  tags           String[]
  isPublic       Boolean          @default(false)
  loadType       LoadType         @default(BODYWEIGHT)
  isUnilateral   Boolean          @default(false)
  movementPattern MovementPattern?
  trackOneRepMax Boolean          @default(false)
  createdBy      User             @relation(fields: [createdById], references: [id])
  createdById    String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  // Muscle loading (1-5 per muscle group)
  muscleLoads    MuscleLoad[]

  // Progression variants (self-referential)
  easierVariantId String?
  easierVariant   Exercise?  @relation("ProgressionEasier", fields: [easierVariantId], references: [id])
  easierOf        Exercise[] @relation("ProgressionEasier")
  harderVariantId String?
  harderVariant   Exercise?  @relation("ProgressionHarder", fields: [harderVariantId], references: [id])
  harderOf        Exercise[] @relation("ProgressionHarder")

  programExercises ProgramExercise[]
  collectionItems  ExerciseCollectionItem[]
  favoritedBy      FavoriteExercise[]
  insights         Insight[]

  // Multi-tenant: oefening is zichtbaar binnen deze praktijk. null = globaal
  // (admin-beheerd / legacy). Gecombineerd met isPublic (true = ook globaal
  // zichtbaar) voor de resolution-regels.
  practiceId  String?
  practice    Practice? @relation(fields: [practiceId], references: [id], onDelete: SetNull)

  @@index([practiceId])
  @@map("exercises")
}

model Practice {
  id          String       @id @default(cuid())
  name        String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  // Clinical Insight Engine — gefaseerde rollout per praktijk.
  cieEnabled  Boolean      @default(false)
  users       User[]
  exercises   Exercise[]
  inviteCodes InviteCode[]

  @@map("practices")
}

/// Physitrack-achtige invite-flow: therapeut genereert een 6-cijfer code,
/// mailt die naar de patiënt. Patiënt logt in met e-mail + geboortejaar + code.
/// Only codeHash is stored — klare code bestaat alleen tijdens de request.
model InviteCode {
  id             String    @id @default(cuid())
  codeHash       String    @unique
  email          String
  name           String
  dateOfBirth    DateTime  // full date; alleen year wordt gecontroleerd bij redeem
  role           UserRole  @default(PATIENT)
  practiceId     String?
  practice       Practice? @relation(fields: [practiceId], references: [id], onDelete: SetNull)
  invitedById    String
  invitedBy      User      @relation("InviteSender", fields: [invitedById], references: [id], onDelete: Cascade)
  expiresAt      DateTime
  usedAt         DateTime?
  usedByUserId  String?    // link naar de aangemaakte/bestaande User na redeem
  attempts       Int       @default(0)
  lastAttemptAt  DateTime?
  createdAt      DateTime  @default(now())

  @@index([email])
  @@index([invitedById])
  @@index([expiresAt])
  @@map("invite_codes")
}

/// AVG art. 32 — audit-trail van kritieke acties (login, data-view, consent, export, delete).
/// Nooit patient-vrije PII direct in metadata; alleen IDs + event-type.
model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  actorEmail  String?  // fallback als user verwijderd is
  event       String   // bv. LOGIN_SUCCESS, INVITE_CREATED, DATA_EXPORTED
  resource    String?  // bv. 'Patient', 'Program', 'SessionLog'
  resourceId  String?
  ip          String?
  userAgent   String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([userId, createdAt])
  @@index([event, createdAt])
  @@index([createdAt])
  @@map("audit_logs")
}

model FavoriteExercise {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  exercise   Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  exerciseId String
  createdAt  DateTime @default(now())

  @@unique([userId, exerciseId])
  @@index([userId])
  @@map("favorite_exercises")
}

model MuscleLoad {
  id         String   @id @default(cuid())
  exercise   Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  exerciseId String
  muscle     String   // e.g. "Quadriceps", "Hamstrings"
  load       Int      // 1-5

  @@unique([exerciseId, muscle])
  @@map("muscle_loads")
}

model ExerciseCollection {
  id          String   @id @default(cuid())
  name        String
  color       String?  // hex color label
  therapist   User     @relation(fields: [therapistId], references: [id])
  therapistId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items ExerciseCollectionItem[]

  @@map("exercise_collections")
}

model ExerciseCollectionItem {
  id           String             @id @default(cuid())
  collection   ExerciseCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  collectionId String
  exercise     Exercise           @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  exerciseId   String
  addedAt      DateTime           @default(now())

  @@unique([collectionId, exerciseId])
  @@map("exercise_collection_items")
}

model Program {
  id           String        @id @default(cuid())
  name         String
  description  String?
  status       ProgramStatus @default(DRAFT)
  type         ProgramType   @default(STRENGTH)
  isTemplate   Boolean       @default(false)
  weeks        Int           @default(4)
  daysPerWeek  Int           @default(3)
  startDate    DateTime?
  endDate      DateTime?
  cardioParams Json?         // CardioParams JSONB for cardio programs

  tendinopathyMode Boolean       @default(false)
  trackOneRepMax   Boolean       @default(false)

  creator   User    @relation("ProgramCreator", fields: [creatorId], references: [id])
  creatorId String
  patient   User?   @relation("ProgramPatient", fields: [patientId], references: [id])
  patientId String?

  // Multi-tenant scope — defensief. Null = legacy (van vóór practice-scoping).
  practiceId String?

  exercises        ProgramExercise[]
  sessionLogs      SessionLog[]
  weekScheduleDays WeekScheduleDay[]
  cardioLogs       CardioLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([practiceId])
  @@index([creatorId, practiceId])
  @@map("programs")
}

model CardioLog {
  id           String          @id @default(cuid())
  program      Program?        @relation(fields: [programId], references: [id])
  programId    String?
  patient      User            @relation(fields: [patientId], references: [id])
  patientId    String
  activity     CardioActivity
  protocol     CardioProtocol
  durationSec  Int             // seconds
  distanceM    Int?            // meters
  avgHeartRate Int?
  maxHeartRate Int?
  zone         Int?            // 1-5
  calories     Int?
  rpe          Int?            // 1-10
  painLevel    Int?            // 0-10
  notes        String?
  intervals    Json?           // interval details JSONB
  completedAt  DateTime        @default(now())
  createdAt    DateTime        @default(now())

  @@map("cardio_logs")
}

model WeekSchedule {
  id          String            @id
  name        String
  description String?
  creatorId   String
  creator     User              @relation("CreatedWeekSchedules", fields: [creatorId], references: [id])
  patientId   String?
  patient     User?             @relation("PatientWeekSchedules", fields: [patientId], references: [id])
  startDate   DateTime?
  endDate     DateTime?
  isTemplate  Boolean           @default(false)
  days        WeekScheduleDay[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  // Multi-tenant scope. Null = legacy.
  practiceId  String?

  @@index([practiceId])
  @@index([creatorId, practiceId])
  @@map("week_schedules")
}

model WeekScheduleDay {
  id             String       @id
  weekScheduleId String
  weekSchedule   WeekSchedule @relation(fields: [weekScheduleId], references: [id], onDelete: Cascade)
  dayOfWeek      Int
  programId      String?
  program        Program?     @relation(fields: [programId], references: [id])

  @@map("week_schedule_days")
}

model ProgramExercise {
  id             String   @id @default(cuid())
  program        Program  @relation(fields: [programId], references: [id], onDelete: Cascade)
  programId      String
  exercise       Exercise @relation(fields: [exerciseId], references: [id])
  exerciseId     String
  week           Int      @default(1)
  day            Int      @default(1)
  order          Int      @default(0)
  sets           Int      @default(3)
  reps           Int      @default(10)
  repUnit        String   @default("reps")
  restTime       Int      @default(60)
  supersetGroup  String?
  supersetOrder  Int      @default(0)
  notes          String?

  @@map("program_exercises")
}

model SessionLog {
  id            String        @id @default(cuid())
  program       Program?      @relation(fields: [programId], references: [id])
  programId     String?
  patient       User          @relation(fields: [patientId], references: [id])
  patientId     String
  status        SessionStatus @default(PENDING)
  scheduledAt   DateTime
  completedAt   DateTime?
  duration      Int?          // seconds
  notes         String?
  painLevel     Int?          // 0-10
  exertionLevel Int?          // 0-10 RPE

  exerciseLogs ExerciseLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("session_logs")
}

model ExerciseLog {
  id                  String     @id @default(cuid())
  session             SessionLog @relation(fields: [sessionId], references: [id])
  sessionId           String
  exerciseId          String
  setsCompleted       Int?
  repsCompleted       Int?
  duration            Int?
  notes               String?
  painLevel           Int?
  weight              Float?     // kg used in last set
  estimatedOneRepMax  Float?     // Epley: weight × (1 + reps/30)
  painDuring          Int?       // 0-10 NRS, tendinopathy mode
  painAfter24h        Int?       // 0-10 NRS, filled via follow-up
  morningStiffness    Int?       // 0-10, filled via follow-up

  @@map("exercise_logs")
}

model Appointment {
  id          String            @id @default(cuid())
  patient     User              @relation("PatientAppointments", fields: [patientId], references: [id])
  patientId   String
  therapist   User              @relation("TherapistAppointments", fields: [therapistId], references: [id])
  therapistId String
  status      AppointmentStatus @default(SCHEDULED)
  scheduledAt DateTime
  duration    Int               // minutes
  notes       String?
  location    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("appointments")
}

model Notification {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  title     String
  body      String
  read      Boolean  @default(false)
  type      String
  data      Json?
  createdAt DateTime @default(now())

  @@map("notifications")
}

model Message {
  id          String   @id @default(cuid())
  sender      User     @relation(fields: [senderId], references: [id])
  senderId    String
  recipientId String
  content     String
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@map("messages")
}

// ─── Research / GDPR ──────────────────────────────────────────────────────────

model ResearchConsent {
  id             String    @id @default(cuid())
  userId         String    @unique
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  consentGiven   Boolean   @default(false)
  consentVersion String    @default("1.0")
  consentGivenAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@map("research_consents")
}

// SECURITY: AnonymousIdMapping is NEVER exposed via API or tRPC.
// Only server-side functions may read/write this table.
model AnonymousIdMapping {
  id          String   @id @default(cuid())
  userId      String   @unique
  anonymousId String   @unique @default(cuid())
  createdAt   DateTime @default(now())

  @@map("anonymous_id_mappings")
}

model AnonymizedRecord {
  id                String   @id @default(cuid())
  // anonymousId references AnonymousIdMapping.anonymousId — no direct FK to prevent reverse lookup
  anonymousId       String
  recordDate        DateTime
  ageAtRecord       Int      // computed from dateOfBirth at time of recording; DOB not stored
  diagnosisCategory String?  // normalized diagnosis category (e.g. "ACL", "Schouder impingement")
  exerciseName      String?
  setsCompleted     Int?
  repsCompleted     Int?
  sessionDuration   Int?     // seconds
  painLevel         Int?     // 0-10
  exertionLevel     Int?     // 0-10 RPE
  promData          Json?    // PROM scores placeholder
  createdAt         DateTime @default(now())

  @@map("anonymized_records")
}

// ─── Clinical Insight Engine (CIE) ───────────────────────────────────────────
// Rule-based suggestion engine for therapists. Patients never see insights.
// See supabase/migrations/20260501_clinical_insight_engine.sql for RLS.

/// Opt-in tracking per patient + patient-objection flag (AVG art. 21).
/// One row per patient; absence = not-yet-enabled.
model PatientInsightStatus {
  patientId             String    @id
  patient               User      @relation("PatientInsightStatusPatient", fields: [patientId], references: [id], onDelete: Cascade)
  enabled               Boolean   @default(false)
  enabledById           String?
  enabledBy             User?     @relation("PatientInsightStatusEnabler", fields: [enabledById], references: [id])
  enabledAt             DateTime?
  disabledAt            DateTime?
  patientObjection      Boolean   @default(false)
  patientObjectionAt    DateTime?
  patientObjectionNote  String?
  updatedAt             DateTime  @updatedAt

  @@map("patient_insight_status")
}

/// Generated insight row — one per detected trigger.
/// patientId-scoped (NOT therapist-scoped) so all treating therapists see the same.
model Insight {
  id                 String         @id @default(cuid())
  patientId          String
  patient            User           @relation("InsightPatient", fields: [patientId], references: [id], onDelete: Cascade)
  signalType         String         // matches InsightRule.signalType
  urgency            InsightUrgency
  title              String
  suggestion         String
  triggerData        Json           // explainability payload — what data triggered this
  exerciseId         String?
  exercise           Exercise?      @relation(fields: [exerciseId], references: [id])
  status             InsightStatus  @default(OPEN)
  statusChangedById  String?
  statusChangedBy    User?          @relation("InsightStatusChanger", fields: [statusChangedById], references: [id])
  statusChangedAt    DateTime?
  snoozedUntil       DateTime?
  createdAt          DateTime       @default(now())
  expiresAt          DateTime

  actions            InsightAction[]

  @@index([patientId, status, urgency, createdAt])
  @@index([patientId, createdAt])
  @@index([patientId, signalType, createdAt])
  @@map("insights")
}

/// Audit trail — every therapist action on an insight.
/// note is ALWAYS optional (no accountability burden on therapist).
model InsightAction {
  id          String            @id @default(cuid())
  insightId   String
  insight     Insight           @relation(fields: [insightId], references: [id], onDelete: Cascade)
  therapistId String
  therapist   User              @relation("InsightActionActor", fields: [therapistId], references: [id])
  action      InsightActionType
  note        String?
  createdAt   DateTime          @default(now())

  @@index([insightId, createdAt])
  @@index([therapistId, createdAt])
  @@map("insight_actions")
}

/// Per-therapist CIE config: which signals, custom thresholds, quiet hours.
model TherapistInsightPref {
  therapistId        String   @id
  therapist          User     @relation(fields: [therapistId], references: [id], onDelete: Cascade)
  signalsEnabled     Json     @default("{}")  // { pain_flare: true, plateau: false, ... }
  customThresholds   Json     @default("{}")  // { pain_flare: { delta: 2 }, ... }
  notificationPrefs  Json     @default("{}")  // { critical: ["email","push"], high: ["digest"] }
  quietHoursStart    Int?                     // 0-23 local hour
  quietHoursEnd      Int?                     // 0-23 local hour
  updatedAt          DateTime @updatedAt

  @@map("therapist_insight_prefs")
}

/// Rule catalog — seeded with 6 rules for v1. Therapists override via TherapistInsightPref.
model InsightRule {
  signalType       String         @id
  category         String         // "pain" | "progression" | "adherence" | "pattern"
  defaultUrgency   InsightUrgency
  defaultConfig    Json
  evidenceRefs     String[]
  enabledGlobally  Boolean        @default(true)
  updatedAt        DateTime       @updatedAt

  @@map("insight_rules")
}

// ─── Revalidatie-protocollen (catalog + per-patient tracker) ─────────────────
// Therapist-facing tracker voor fasegebonden revalidatie-criteria (stoplicht-UI).
// Admin beheert de catalog (RehabProtocol/Phase/Criterion); therapeut activeert
// per patient en vinkt criteria R/O/G af.

/// Admin-beheerd protocol uit een evidence-based bron (bv Melbourne VKB 2.0).
model RehabProtocol {
  id              String       @id @default(cuid())
  key             String       @unique // stabiele seed-key, bv "melbourne-acl-2"
  name            String
  description     String?
  specialty       String       // "knee_acl", "meniscus", "shoulder"...
  sourceReference String?      // bv "Cooper & Hughes (2024). Melbourne VKB Protocol 2.0"
  isActive        Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  phases          RehabPhase[]
  trackers        PatientRehabTracker[]

  @@map("rehab_protocols")
}

/// E\u00e9n fase binnen een protocol (bv "Fase 2 \u2014 Kracht en Neuromusculaire Controle").
model RehabPhase {
  id                String            @id @default(cuid())
  protocolId        String
  protocol          RehabProtocol     @relation(fields: [protocolId], references: [id], onDelete: Cascade)
  order             Int               // 0 = pre-op, 1..N = reguliere fases
  shortName         String            // bv "Pre-op", "Fase 1"
  name              String            // volledige naam
  description       String?
  keyGoals          String[]          // 3 belangrijkste doelen als bullets
  // Indicatieve tijdlijn t.o.v. operatie (weken). Negatieve waarde = pre-op.
  // null = niet van toepassing / doorlopend.
  typicalStartWeek  Int?
  typicalEndWeek    Int?

  criteria          RehabCriterion[]

  @@unique([protocolId, order])
  @@map("rehab_phases")
}

/// Een afvinkbaar criterium/uitkomstmaat binnen een fase.
model RehabCriterion {
  id              String                  @id @default(cuid())
  phaseId         String
  phase           RehabPhase              @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  order           Int
  name            String                  // bv "Passieve Knie Flexie"
  testDescription String                  // hoe de test uit te voeren
  reference       String?                 // bv "Norkin & White, 1995"
  targetValue     String                  // doel als tekst, bv ">125\u00b0" of "90% vs contralateral"
  targetUnit      String?                 // "\u00b0", "%", "reps", "seconden"
  inputType       RehabCriterionInputType @default(NUMERIC)
  isBonus         Boolean                 @default(false)

  // Bilaterale kracht-metingen met auto-stoplicht:
  //   * isBilateral=true   \u2192 therapeut vult L + R waarde in, systeem berekent LSI
  //   * newtonMinGreen     \u2192 absolute minimum Newton-waarde per zijde voor GROEN
  //   * newtonMinOrange    \u2192 absolute minimum Newton-waarde per zijde voor ORANJE (onder = rood)
  //   * lsiMinGreen        \u2192 minimum LSI% (min/max * 100) voor GROEN (typisch 90)
  //   * lsiMinOrange       \u2192 minimum LSI% voor ORANJE (typisch 80)
  // Status wordt GROEN als BEIDE N\u2265Green \u00e9n LSI\u2265Green. ORANJE als N\u2265Orange + LSI\u2265Orange.
  isBilateral       Boolean @default(false)
  newtonMinGreen    Int?
  newtonMinOrange   Int?
  lsiMinGreen       Int?
  lsiMinOrange      Int?

  statuses        RehabCriterionStatus[]

  @@unique([phaseId, order])
  @@map("rehab_criteria")
}

/// Per-patient activation van \u00e9\u00e9n protocol tegelijk (toggle + dropdown).
model PatientRehabTracker {
  patientId      String        @id
  patient        User          @relation("RehabTrackerPatient", fields: [patientId], references: [id], onDelete: Cascade)
  protocolId     String
  protocol       RehabProtocol @relation(fields: [protocolId], references: [id])
  activatedById  String
  activatedBy    User          @relation("RehabTrackerActivator", fields: [activatedById], references: [id])
  activatedAt    DateTime      @default(now())
  deactivatedAt  DateTime?
  // Operatiedatum: basis voor indicatieve fase-berekening (week-based).
  surgeryDate    DateTime?
  // Optioneel: datum van blessure (voor pre-op contextualisering).
  injuryDate     DateTime?
  notes          String?
  updatedAt      DateTime      @updatedAt

  @@map("patient_rehab_trackers")
}

/// Per patient \u00d7 criterium de R/O/G status + meetwaarde + datum.
model RehabCriterionStatus {
  id                String                    @id @default(cuid())
  patientId         String
  criterionId       String
  criterion         RehabCriterion            @relation(fields: [criterionId], references: [id], onDelete: Cascade)
  status            RehabCriterionStatusValue @default(NOT_MET)
  measurementValue  String?                   // vrije tekst: "128\u00b0", "95%", "22 reps"
  measurementDate   DateTime?
  notes             String?
  updatedById       String
  updatedBy         User                      @relation("RehabStatusUpdater", fields: [updatedById], references: [id])
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  @@unique([patientId, criterionId])
  @@index([patientId])
  @@map("rehab_criterion_status")
}

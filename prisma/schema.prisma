generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  THERAPIST
  PATIENT
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum ProgramStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum ExerciseCategory {
  STRENGTH
  MOBILITY
  PLYOMETRICS
  CARDIO
  STABILITY
}

enum BodyRegion {
  KNEE
  SHOULDER
  BACK
  ANKLE
  HIP
  FULL_BODY
  CERVICAL
  THORACIC
  LUMBAR
  ELBOW
  WRIST
  FOOT
}

enum Difficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum MediaType {
  UPLOAD
  YOUTUBE
  VIMEO
}

enum SessionStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  role          UserRole  @default(PATIENT)
  avatarUrl     String?
  phone         String?
  dateOfBirth   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Therapist fields
  specialty     String?
  bio           String?
  licenseNumber String?

  // MFA
  mfaEnabled    Boolean   @default(false)
  mfaSecret     String?

  // Relations
  therapistPatients     PatientTherapist[]     @relation("TherapistRelation")
  patientTherapists     PatientTherapist[]     @relation("PatientRelation")
  createdPrograms       Program[]              @relation("ProgramCreator")
  patientPrograms       Program[]              @relation("ProgramPatient")
  exercises             Exercise[]
  collections           ExerciseCollection[]
  appointments          Appointment[]          @relation("PatientAppointments")
  therapistAppointments Appointment[]          @relation("TherapistAppointments")
  sessionLogs           SessionLog[]
  notifications         Notification[]
  messages              Message[]

  @@map("users")
}

model PatientTherapist {
  id          String   @id @default(cuid())
  therapist   User     @relation("TherapistRelation", fields: [therapistId], references: [id])
  therapistId String
  patient     User     @relation("PatientRelation", fields: [patientId], references: [id])
  patientId   String
  createdAt   DateTime @default(now())
  isActive    Boolean  @default(true)
  notes       String?

  @@unique([therapistId, patientId])
  @@map("patient_therapists")
}

model Exercise {
  id             String           @id @default(cuid())
  name           String
  description    String?
  category       ExerciseCategory
  bodyRegion     BodyRegion[]
  difficulty     Difficulty       @default(BEGINNER)
  mediaType      MediaType?
  videoUrl       String?
  thumbnailUrl   String?
  instructions   String[]
  tips           String[]
  tags           String[]
  isPublic       Boolean          @default(false)
  createdBy      User             @relation(fields: [createdById], references: [id])
  createdById    String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  // Muscle loading (1-5 per muscle group)
  muscleLoads    MuscleLoad[]

  // Progression variants (self-referential)
  easierVariantId String?
  easierVariant   Exercise?  @relation("ProgressionEasier", fields: [easierVariantId], references: [id])
  easierOf        Exercise[] @relation("ProgressionEasier")
  harderVariantId String?
  harderVariant   Exercise?  @relation("ProgressionHarder", fields: [harderVariantId], references: [id])
  harderOf        Exercise[] @relation("ProgressionHarder")

  programExercises ProgramExercise[]
  collectionItems  ExerciseCollectionItem[]

  @@map("exercises")
}

model MuscleLoad {
  id         String   @id @default(cuid())
  exercise   Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  exerciseId String
  muscle     String   // e.g. "Quadriceps", "Hamstrings"
  load       Int      // 1-5

  @@unique([exerciseId, muscle])
  @@map("muscle_loads")
}

model ExerciseCollection {
  id          String   @id @default(cuid())
  name        String
  color       String?  // hex color label
  therapist   User     @relation(fields: [therapistId], references: [id])
  therapistId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items ExerciseCollectionItem[]

  @@map("exercise_collections")
}

model ExerciseCollectionItem {
  id           String             @id @default(cuid())
  collection   ExerciseCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  collectionId String
  exercise     Exercise           @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  exerciseId   String
  addedAt      DateTime           @default(now())

  @@unique([collectionId, exerciseId])
  @@map("exercise_collection_items")
}

model Program {
  id          String        @id @default(cuid())
  name        String
  description String?
  status      ProgramStatus @default(DRAFT)
  startDate   DateTime?
  endDate     DateTime?

  creator   User   @relation("ProgramCreator", fields: [creatorId], references: [id])
  creatorId String
  patient   User   @relation("ProgramPatient", fields: [patientId], references: [id])
  patientId String

  exercises   ProgramExercise[]
  sessionLogs SessionLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("programs")
}

model ProgramExercise {
  id         String   @id @default(cuid())
  program    Program  @relation(fields: [programId], references: [id])
  programId  String
  exercise   Exercise @relation(fields: [exerciseId], references: [id])
  exerciseId String
  order      Int
  sets       Int?
  reps       Int?
  duration   Int?     // seconds
  restTime   Int?     // seconds
  notes      String?
  dayOfWeek  Int[]    // 0=Sunday, 6=Saturday

  @@map("program_exercises")
}

model SessionLog {
  id            String        @id @default(cuid())
  program       Program       @relation(fields: [programId], references: [id])
  programId     String
  patient       User          @relation(fields: [patientId], references: [id])
  patientId     String
  status        SessionStatus @default(PENDING)
  scheduledAt   DateTime
  completedAt   DateTime?
  duration      Int?          // seconds
  notes         String?
  painLevel     Int?          // 0-10
  exertionLevel Int?          // 0-10 RPE

  exerciseLogs ExerciseLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("session_logs")
}

model ExerciseLog {
  id            String     @id @default(cuid())
  session       SessionLog @relation(fields: [sessionId], references: [id])
  sessionId     String
  exerciseId    String
  setsCompleted Int?
  repsCompleted Int?
  duration      Int?
  notes         String?
  painLevel     Int?

  @@map("exercise_logs")
}

model Appointment {
  id          String            @id @default(cuid())
  patient     User              @relation("PatientAppointments", fields: [patientId], references: [id])
  patientId   String
  therapist   User              @relation("TherapistAppointments", fields: [therapistId], references: [id])
  therapistId String
  status      AppointmentStatus @default(SCHEDULED)
  scheduledAt DateTime
  duration    Int               // minutes
  notes       String?
  location    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("appointments")
}

model Notification {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  title     String
  body      String
  read      Boolean  @default(false)
  type      String
  data      Json?
  createdAt DateTime @default(now())

  @@map("notifications")
}

model Message {
  id          String   @id @default(cuid())
  sender      User     @relation(fields: [senderId], references: [id])
  senderId    String
  recipientId String
  content     String
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@map("messages")
}
